# ─────────────────────────────────────────────────────────────
# .gitignore — Racine du projet Todo App
# ─────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════
# Node.js / JavaScript
# ═══════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ═══════════════════════════════════════════════════════════════
# Build artifacts
# ═══════════════════════════════════════════════════════════════
dist/
build/
.next/
out/
*.tgz

# ═══════════════════════════════════════════════════════════════
# Environment & Secrets (CRITICAL — ne jamais commit)
# ═══════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
!.env.*.example

# ═══════════════════════════════════════════════════════════════
# Terraform
# ═══════════════════════════════════════════════════════════════
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!*.tfvars.example
*.tfvars.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.lock.hcl
terraform.rc
terraform.log

# ═══════════════════════════════════════════════════════════════
# Ansible
# ═══════════════════════════════════════════════════════════════
*.retry
*.vault_pass
ansible/inventory/hosts.ini

# ═══════════════════════════════════════════════════════════════
# SSH Keys & Certificates (CRITICAL — ne jamais commit)
# ═══════════════════════════════════════════════════════════════
*.pem
*.key
*.pub
id_rsa
id_ed25519
deploy_key
my-ec2-key
my-ec2-key.pub
*.crt
*.csr

# ═══════════════════════════════════════════════════════════════
# Docker
# ═══════════════════════════════════════════════════════════════
*.tar
*.tar.gz
docker-compose.override.yml

# ═══════════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════════
logs/
*.log

# ═══════════════════════════════════════════════════════════════
# OS files
# ═══════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════════
# IDE / Editor
# ═══════════════════════════════════════════════════════════════
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.code-workspace

# ═══════════════════════════════════════════════════════════════
# Database dumps
# ═══════════════════════════════════════════════════════════════
*.sql
*.sqlite
*.db
*.dump

# ═══════════════════════════════════════════════════════════════
# Misc — fichiers lourds / temporaires
# ═══════════════════════════════════════════════════════════════
*.zip
*.rar
*.7z
*.iso
*.dmg
*.exe
*.msi
tmp/
temp/
.cache/
coverage/
